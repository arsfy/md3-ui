{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"files": {
		"includes": ["**/*.{js,jsx,ts,tsx}", "!dist", "!src/components/ui"]
	},
	"formatter": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "warn",
				"noUnusedVariables": {
					"level": "warn",
					"options": {
						"ignoreRestSiblings": true
					}
				}
			},
			"style": {
				"noNonNullAssertion": "off"
			}
		}
	},
	"assist": {
		"actions": {
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							[{ "type": true }],
							":BLANK_LINE:",
							[":NODE:"],
							":BLANK_LINE:",
							[":PACKAGE:", "~/**"],
							":BLANK_LINE:",
							[":PATH:"]
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"jsxQuoteStyle": "single",
			"trailingCommas": "es5",
			"semicolons": "always",
			"indentStyle": "space",
			"indentWidth": 4,
			"lineWidth": 100,
			"lineEnding": "lf",
			"bracketSpacing": true
		}
	}
}
